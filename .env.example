# Any standard Postgres connection string (Neon, Railway, RDS, Docker, …).
# For local dev with `docker compose up -d`:
DATABASE_URL=postgres://malabarjs:malabarjs@localhost:5432/malabarjs

# Optional Discord/Slack-compatible webhook notified on new form submissions.
NUXT_FORMS_WEBHOOK_URL=

# Bearer token for the /admin site controls. Generate with:
#   openssl rand -hex 24
# Leave unset to disable the admin endpoint entirely.
NUXT_ADMIN_TOKEN=
